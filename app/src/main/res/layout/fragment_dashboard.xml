<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_primary"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:paddingHorizontal="20dp"
            app:title="Dashboard"
            app:titleTextAppearance="@style/TextAppearance.Routinely.HeadlineLarge"
            app:titleMarginStart="0dp" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="32dp">

            <!-- Hero Welcome Card with Gradient Background -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@drawable/bg_welcome_gradient"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/greeting_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning, User!"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/date_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="March 15, 2025"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:alpha="0.85" />

                    <!-- Motivational Quote with Glass Effect -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#40FFFFFF"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#20FFFFFF">

                        <TextView
                            android:id="@+id/motivational_quote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp"
                            android:text="&quot;Small steps every day lead to big change.&quot;"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:lineHeight="24dp"
                            android:textStyle="italic"
                            android:alpha="0.95" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Progress - Redesigned with Side-by-Side Layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Progress"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.01" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="24dp"
                        android:gravity="center_vertical">

                        <!-- Progress Ring -->
                        <FrameLayout
                            android:layout_width="140dp"
                            android:layout_height="140dp">

                            <com.example.moodflow.views.ProgressRingView
                                android:id="@+id/progress_ring"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/progress_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="65%"
                                    android:textSize="32sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/progress_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Complete"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_secondary" />

                            </LinearLayout>

                        </FrameLayout>

                        <!-- Stats Grid -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="24dp">

                            <!-- Habits Stat -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="12dp"
                                android:background="@drawable/bg_stat_item"
                                android:layout_marginBottom="10dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="@color/primary_light">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_habits"
                                        android:tint="@color/primary" />

                                </com.google.android.material.card.MaterialCardView>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Habits"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_secondary"
                                        android:textAllCaps="true"
                                        android:letterSpacing="0.05" />

                                    <TextView
                                        android:id="@+id/habits_completed_text"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="3 of 5"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_primary"
                                        android:fontFamily="sans-serif-medium" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Streak Stat -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="12dp"
                                android:background="@drawable/bg_stat_item"
                                android:layout_marginBottom="10dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="@color/orange_light">

                                    <com.example.moodflow.views.FlameView
                                        android:id="@+id/streak_flame"
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center" />

                                </com.google.android.material.card.MaterialCardView>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Streak"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_secondary"
                                        android:textAllCaps="true"
                                        android:letterSpacing="0.05" />

                                    <TextView
                                        android:id="@+id/streak_text"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="5 days"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_primary"
                                        android:fontFamily="sans-serif-medium" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Best Streak Stat -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="12dp"
                                android:background="@drawable/bg_stat_item">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="@color/gold_light">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_trophy"
                                        android:tint="@color/gold" />

                                </com.google.android.material.card.MaterialCardView>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:letterSpacing="0.05"
                                        android:text="Best"
                                        android:textAllCaps="true"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/streak_best"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-medium"
                                        android:text="12 days"
                                        android:textColor="@color/text_primary"
                                        android:textSize="18sp"
                                        android:textStyle="bold" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Stats Cards - Horizontal Scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Water Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/water_card"
                        android:layout_width="180dp"
                        android:layout_height="220dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="28dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <!-- Gradient background for visual depth -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp"
                            android:background="@drawable/bg_water_gradient">

                            <!-- Top Icon -->
                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/ic_water_drop"
                                android:tint="@android:color/white"
                                android:layout_marginBottom="12dp" />

                            <!-- Title -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hydration"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/white"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="-0.01"
                                android:layout_marginBottom="8dp" />

                            <!-- Wave Progress Circle -->
                            <FrameLayout
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/bg_wave_circle"
                                android:gravity="center">

                                <com.example.moodflow.views.WaveView
                                    android:id="@+id/water_wave"
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    app:waveColor="@color/water_light" />

                                <TextView
                                    android:id="@+id/water_percentage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="75%"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white" />
                            </FrameLayout>

                            <!-- Subtitle -->

                            <TextView
                                android:id="@+id/water_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                    android:text="6 / 8 glasses"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="sans-serif-medium" />




                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>


                    <!-- Mood Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/mood_card"
                        android:layout_width="180dp"
                        android:layout_height="200dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:cardElevation="6dp"
                        app:cardCornerRadius="28dp"
                        app:rippleColor="@color/primary_light"
                        app:strokeWidth="0dp">

                        <!-- Gradient Background -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp"
                            android:background="@drawable/bg_mood_gradient">
                            <!-- Mood Icon -->
                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:src="@drawable/ic_mood"
                                android:tint="@color/white"
                                android:contentDescription="Mood Icon" />

                            <!-- Mood Title -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="Mood"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.02" />

                            <!-- Emoji with Trend Arrow -->
                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp">
                                <TextView
                                    android:id="@+id/mood_emoji"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="😊"
                                    android:textSize="42sp" />
                                <ImageView
                                    android:id="@+id/mood_trend"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="end|top"
                                    android:src="@drawable/ic_trend_up"
                                    app:tint="@color/success" />
                            </FrameLayout>

                            <!-- Mood Text -->
                            <TextView
                                android:id="@+id/mood_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Feeling happy"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:fontFamily="sans-serif-medium"
                                />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>


                    <!-- Placeholder for more cards -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="1dp" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Active Habits Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/active_habits_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginBottom="24dp"
                app:cardElevation="8dp"
                app:cardCornerRadius="28dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="20dp">

                    <!-- Title and View All -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today's Habits"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="-0.01" />

                            <TextView
                                android:id="@+id/active_habits_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Stay consistent by tackling these next."
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/view_all_habits_button"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                    <!-- Active Habits ChipGroup -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/active_habits_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:paddingBottom="8dp"
                        app:singleLine="false"
                        app:singleSelection="false"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp">

                        <!-- Example Chips -->
                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drink Water"
                            android:textColor="@android:color/black"
                            app:chipBackgroundColor="@color/white"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/primary"
                            app:chipCornerRadius="16dp"
                            app:rippleColor="@color/primary_light"
                            android:elevation="2dp" />

                        <com.google.android.material.chip.Chip
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Meditate"
                            android:textColor="@android:color/black"
                            app:chipBackgroundColor="@color/white"
                            app:chipStrokeWidth="1dp"
                            app:chipStrokeColor="@color/primary"
                            app:chipCornerRadius="16dp"
                            android:elevation="2dp" />

                    </com.google.android.material.chip.ChipGroup>


                    <!-- Empty state text -->
                    <TextView
                        android:id="@+id/active_habits_empty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="You're all caught up! 🎉"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- Completed Habits -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/completed_habits_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/completed_habits_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today's Wins"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="-0.01" />

                            <TextView
                                android:id="@+id/completed_habits_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Already crushed"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/view_all_completed_button"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/completed_habits_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleLine="false"
                        app:singleSelection="false"
                        app:chipSpacingHorizontal="10dp"
                        app:chipSpacingVertical="10dp" />

                    <TextView
                        android:id="@+id/completed_habits_empty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="No habits completed yet. Keep going!"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Action Buttons - Full Width Stacked -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/log_water_button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:text="Log Water"
                    android:textSize="16sp"
                    android:textStyle="bold"
