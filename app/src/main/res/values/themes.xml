<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme using Material 3 -->
    <style name="Base.Theme.Routinely" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/white</item>
        <!-- Customize your theme here -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/background_soft</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/light_gray</item>
    </style>

    <style name="Theme.Routinely" parent="Base.Theme.Routinely" />
    
    <!-- Custom theme for the dashboard with solid background (no gradients) -->
    <style name="Theme.Routinely.Dashboard" parent="Theme.Routinely">
        <item name="android:windowBackground">@color/background_solid</item>
    </style>
    
    <!-- Custom elevated card style -->
    <style name="Widget.Routinely.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    
    <!-- Custom filled card style -->
    <style name="Widget.Routinely.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/background_soft</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    
    <!-- Custom outlined card style -->
    <style name="Widget.Routinely.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/light_gray</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    
    <!-- Custom chip styles -->
    <style name="Widget.Routinely.Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/primary_soft</item>
        <item name="android:textColor">@color/primary</item>
        <item name="chipIconTint">@color/primary</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>
    
    <style name="Widget.Routinely.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/primary_soft</item>
        <item name="android:textColor">@color/primary</item>
        <item name="chipIconTint">@color/primary</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>
    
    <style name="Widget.Routinely.Chip.Suggestion" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/background_soft</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>
    
    <!-- Custom segmented button style -->
    <style name="Widget.Routinely.SegmentedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:minHeight">48dp</item>
    </style>
</resources>